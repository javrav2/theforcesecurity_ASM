# Local-development environment.
# Copy this file to `.env` (which is git-ignored) and fill in API keys.
#
#   cp .env.local.example .env
#   # then edit .env
#
# Only the secrets need real values for the Oracle agent to function;
# everything else has sensible defaults.

# ── Required for the AI agent (Aegis Oracle + chat) ────────────────────
# Anthropic is the preferred provider (claude-sonnet-4-5 is the default model
# in aegis-oracle/cmd/aegis-oracle/config.yaml). Set either ANTHROPIC_API_KEY
# or OPENAI_API_KEY — the daemon auto-detects.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Optional: subcat passive subdomain sources ─────────────────────────
# subcat reads ~/.subcat/config.yaml at runtime. Set these keys to unlock
# paid modules; free modules (dnsdumpster, hackertarget, anubis, crt.sh,
# wayback, threatcrowd, dnsarchive) work without any keys.
SUBCAT_VIRUSTOTAL_KEY=
SUBCAT_SECURITYTRAILS_KEY=
SUBCAT_SHODAN_KEY=
SUBCAT_BINARYEDGE_KEY=
SUBCAT_CENSYS_ID=
SUBCAT_CENSYS_SECRET=

# ── Optional: improves CVE intel + exploit signals ─────────────────────
# Free key at https://cloud.projectdiscovery.io — raises rate limits on
# vulnx (CVE intelligence + on-demand ingest source).
PDCP_API_KEY=

# https://vulncheck.com — primary signal for confirmed-exploited evidence
# (KEV-class, weaponized, threat-actor association). Without it the X
# component of OPES still works but loses VulnCheck-specific signals.
VULNCHECK_API_TOKEN=

# Free key at https://nvd.nist.gov/developers/request-an-api-key — raises
# the per-IP NVD rate limit, used as a fallback when vulnx doesn't have
# a brand-new CVE id yet.
NVD_API_KEY=

# ── Default admin (auto-created on first backend startup) ──────────────
# Change DEFAULT_ADMIN_PASSWORD before exposing this anywhere.
DEFAULT_ADMIN_EMAIL=admin@theforce.security
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── Database / Redis (override only if you want non-default ports) ─────
POSTGRES_USER=asm_user
POSTGRES_PASSWORD=asm_password
POSTGRES_DB=asm_db
DB_PORT=5432
REDIS_PORT=6379

# ── App secrets ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=please-change-me-locally-only

# ── Local ports ────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
ORACLE_PORT=8742
ADMINER_PORT=8080
